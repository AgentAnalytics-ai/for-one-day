$ErrorActionPreference = "Stop"
$CommitMessage = "chore: deploy"
$ExpectedBranch = "main"
$SkipChecks = $false
# Git push to main auto-deploys on Vercel. CLI deploy is optional (requires vercel >= 47.2.2).
$NoVercel = $true

function Invoke-NpmCheck([string]$Script) {
  npm run $Script
  if ($LASTEXITCODE -ne 0) { throw "npm run $Script failed (exit $LASTEXITCODE)" }
}

if (-not (Test-Path .\package.json)) { throw "Run from repo root (package.json)." }
if (-not (Get-Command git -ErrorAction SilentlyContinue)) { throw "git not found." }
if ((git rev-parse --is-inside-work-tree).Trim() -ne "true") { throw "Not a git repo." }

$branch = (git branch --show-current).Trim()
if ($branch -ne $ExpectedBranch) { throw "Branch is $branch, expected $ExpectedBranch" }

$status = git status --porcelain
if ($status) {
  if (-not $SkipChecks) {
    Invoke-NpmCheck "type-check"
    # next lint removed in Next 16 — Vercel build is the lint/build gate
  }
  if ([string]::IsNullOrWhiteSpace($CommitMessage)) { $CommitMessage = Read-Host "Commit message" }
  git add -A
  git commit -m $CommitMessage
  if ($LASTEXITCODE -ne 0) { throw "git commit failed" }
}

git push origin $branch
if ($LASTEXITCODE -ne 0) { throw "git push failed" }

Write-Host ""
Write-Host "Pushed to origin/$branch — Vercel auto-deploys from GitHub (check vercel.com dashboard)." -ForegroundColor Green

if (-not $NoVercel) {
  if (-not (Get-Command vercel -ErrorAction SilentlyContinue)) {
    throw "vercel not found: npm i -g vercel@latest"
  }
  vercel --prod --yes
  if ($LASTEXITCODE -ne 0) {
    Write-Host "vercel --prod failed (CLI may be outdated). Push already triggered deploy if GitHub is linked." -ForegroundColor Yellow
  }
}
